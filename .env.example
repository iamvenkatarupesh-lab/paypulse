# ============================================
# PayPulse — Docker Compose environment template
# Copy to .env and adjust values for local dev.
# ============================================

# PostgreSQL
POSTGRES_USER=paypulse
POSTGRES_PASSWORD=paypulse_dev_password
POSTGRES_DB=paypulse

# Backend
BACKEND_LOG_LEVEL=info

# Frontend
# Public API base URL (visible to browser; localhost from host perspective)
NEXT_PUBLIC_API_URL=http://localhost:3001
